{
  "name": "resub-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,green\" \"npm run dev --workspace=frontend\" \"npm run start --workspace=backend\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
